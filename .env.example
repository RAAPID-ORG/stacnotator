# PostgreSQL Configuration
POSTGRES_DB=stacnotator # Postgres DB Name
POSTGRES_USER=stacnotator # Postgres User Name
POSTGRES_PASSWORD=changeme_secure_password_here # Postgres Password
POSTGRES_PORT=5433 # Host port for Postgres (container always uses 5432 internally)

# Earth Engine Configuration
# Provide host path to your EE private key JSON file
EE_SERVICE_ACCOUNT=your-service-account@project.iam.gserviceaccount.com # Earth Engine Service Account Email
EE_PRIVATE_KEY_PATH_HOST=/path/to/your/ee-private-key.json # Path to Earth Engine Private Key (Json)

# Backend Configuration
BACKEND_PORT=8000

# Auth Configuration
# For local single-user mode (no Firebase needed): set AUTH_PROVIDER=local
# For Firebase auth: set AUTH_PROVIDER=firebase and fill in Firebase vars below
AUTH_PROVIDER=local
# FIREBASE_CREDENTIALS_PATH_HOST=/path/to/your/firebase-credentials.json

# Tiler Configuration (tile serving service)
TILER_PORT=8001
TILER_WORKERS=2
TILER_TIMEOUT=120
TILER_MAX_REQUESTS=500

# Frontend Configuration
FRONTEND_PORT=5173
# Production: Use full URL to override hardcoded localhost:8000 in generated client
# Development: http://localhost:8000 for direct backend access (replace port with the configured BACKEND_PORT if different)
VITE_API_BASE_URL=http://localhost:8000
# Tiler service URL for tile requests (defaults to VITE_API_BASE_URL if not set)
VITE_TILER_BASE_URL=http://localhost:8001

# Firebase frontend config (leave commented out for local auth mode)
# VITE_FIREBASE_API_KEY=firebase_api_key_here
# VITE_FIREBASE_AUTH_DOMAIN=app-name.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=project-id-here

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,https://yourdomain.com


####################################################################################
#                Production only settings below                                    #
####################################################################################

# Gunicorn Worker Configuration
# Formula: (2 x CPU_cores) + 1
# Development: 2-4 workers
# Production (8 CPU): 17 workers
WORKERS=4
TIMEOUT=60
GRACEFUL_TIMEOUT=30
KEEPALIVE=5
# Restart workers after N requests to prevent memory leaks
MAX_REQUESTS=1000
MAX_REQUESTS_JITTER=50

# Application Environment
APP_ENV=production
