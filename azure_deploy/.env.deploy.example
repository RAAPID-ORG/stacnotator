# Azure Deployment Configuration
# Copy this file to .env.deploy and fill in your values:
#   cp azure_deploy/.env.deploy.example azure_deploy/.env.deploy
#
# Then source it before running deploy scripts:
#   source azure_deploy/.env.deploy

# Azure Resource Group (required for all deploy scripts)
RESOURCE_GROUP=your-resource-group-name

# Staging database password (used by docker-compose.staging.yml and make-staging-env.sh)
STAGING_DB_PASSWORD=change-this-password

# Optional: override image tag (defaults to git commit SHA)
# IMAGE_TAG=v1.0.0
