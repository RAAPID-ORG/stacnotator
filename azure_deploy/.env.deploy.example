# Azure Deployment Configuration
#
# Create per-environment files:
#   cp azure_deploy/.env.deploy.example azure_deploy/.env.deploy.prod
#   cp azure_deploy/.env.deploy.example azure_deploy/.env.deploy.dev
#
# Then pass prod or dev as an argument to the scripts:
#   ./azure_deploy/deploy-app.sh prod

# Environment name (prod|dev)
DEPLOY_ENV=prod

# Azure Resource Group (required for all deploy scripts)
RESOURCE_GROUP=your-resource-group-name

# Credentials (used by upload-secrets.sh and deploy-app.sh)
FIREBASE_CREDS=backend/config/firebase-credentials.json
EE_CREDS=backend/config/ee-private-key.json
EE_SERVICE_ACCOUNT=your-sa@your-project.iam.gserviceaccount.com
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=

# Optional: override image tag (defaults to git commit SHA)
# IMAGE_TAG=v1.0.0

# Optional: staging database password (used by docker-compose.staging.yml)
# STAGING_DB_PASSWORD=change-this-password
